generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  barcode     String?  @unique
  sku         String?  @unique
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  costPrice   Float    // Precio de costo
  salePrice   Float    // Precio de venta
  image       String?  // Base64 data URL for product image
  stock       Int      @default(0)
  minStock    Int      @default(5)
  unit        String   @default("unidad")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  movements   InventoryMovement[]
  stocks      ProductStock[]
  purchaseItems PurchaseItem[]
  saleItems   SaleItem[]
  repairParts RepairPart[]
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String   @default("PRINCIPAL") // PRINCIPAL, VENTAS, SECUNDARIO
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stocks      ProductStock[]
  movementsFrom InventoryMovement[] @relation("FromWarehouse")
  movementsTo   InventoryMovement[] @relation("ToWarehouse")
  purchaseItems PurchaseItem[]
  saleItems   SaleItem[]
}

model ProductStock {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stock       Int       @default(0)
  minStock    Int       @default(5)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model InventoryMovement {
  id              String     @id @default(cuid())
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  type            String     // ENTRADA, SALIDA, AJUSTE, COMPRA, VENTA, MERMA, TRANSFERENCIA
  quantity        Int
  previousStock   Int
  newStock        Int
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  reason          String?
  referenceId     String?
  createdAt       DateTime   @default(now())
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchases Purchase[]
}

model Purchase {
  id            String   @id @default(cuid())
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  invoiceNumber String?
  totalAmount   Float
  status        String   @default("PENDIENTE")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         PurchaseItem[]
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Int
  costPrice   Float
  subtotal    Float
}

model Sale {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  cashRegisterId  String?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])
  paymentMethod   String        // EFECTIVO, TARJETA, CUENTA_CASA, MIXTO
  subtotal        Float
  discount        Float         @default(0)
  total           Float
  costTotal       Float         // Total al precio de costo
  tableNumber     Int?          // Número de mesa (solo para modo cafetería)
  customerName    String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           SaleItem[]
  payments        SalePayment[]
}

model SaleItem {
  id           String    @id @default(cuid())
  saleId       String
  sale         Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  quantity     Int
  costPrice    Float
  salePrice    Float
  subtotal     Float
  costSubtotal Float
}

model SalePayment {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    String   // EFECTIVO, TARJETA, CUENTA_CASA
  amount    Float
  createdAt DateTime @default(now())

  @@index([saleId])
}

model CashRegister {
  id                    String         @id @default(cuid())
  openingAmount         Float
  closingAmount         Float?
  expectedAmount        Float?
  difference            Float?
  status                String         @default("ABIERTA")
  openedAt              DateTime       @default(now())
  closedAt              DateTime?
  openingBillBreakdown  String?        // JSON string with bill denomination counts for opening
  closingBillBreakdown  String?        // JSON string with bill denomination counts for closing
  sales                 Sale[]
  movements             CashMovement[]
  expenses              Expense[]
}

model CashMovement {
  id             String        @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister  @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  type           String        // ENTRADA, SALIDA
  amount         Float
  reason         String
  createdAt      DateTime      @default(now())
}

model Repair {
  id            String       @id @default(cuid())
  customerName  String
  customerPhone String?
  device        String
  brand         String?
  model         String?
  serialNumber  String?
  issue         String
  diagnosis     String?
  repairCost    Float        @default(0)
  partsCost     Float        @default(0)
  totalCost     Float        @default(0)
  status        String       @default("RECIBIDO")
  receivedAt    DateTime     @default(now())
  completedAt   DateTime?
  deliveredAt   DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  parts         RepairPart[]
}

model RepairPart {
  id        String  @id @default(cuid())
  repairId  String
  repair    Repair  @relation(fields: [repairId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  partName  String
  quantity  Int     @default(1)
  costPrice Float   @default(0)
  salePrice Float   @default(0)
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]") // JSON array of permission strings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id        String   @id @default(cuid())
  username   String   @unique
  password   String
  name      String
  email     String?
  phone     String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id              String        @id @default(cuid())
  description     String
  amount          Float
  category        String        @default("OTRO") // ALQUILER, SERVICIOS, SALARIOS, TRANSPORTE, MARKETING, MANTENIMIENTO, IMPUESTOS, OTRO
  paymentMethod   String        @default("EFECTIVO") // EFECTIVO, TARJETA, TRANSFERENCIA
  date            DateTime      @default(now())
  cashRegisterId  String?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])
  recipient       String?       // A quién se pagó
  receiptNumber   String?       // Número de recibo/factura
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Currency {
  id          String   @id @default(cuid())
  code        String   @unique   // ISO 4217 code: ARS, USD, EUR, etc.
  name        String             // Argentine Peso, US Dollar, etc.
  symbol      String             // $, US$, €, etc.
  locale      String   @default("es-AR") // For Intl.NumberFormat
  isBase      Boolean  @default(false)   // Is this the base (primary) currency?
  exchangeRate Float   @default(1)       // Rate relative to base currency (1 base = X of this currency)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExchangeRateHistory {
  id           String   @id @default(cuid())
  fromCurrency String             // ISO code
  toCurrency   String             // ISO code
  rate         Float              // 1 fromCurrency = X toCurrency
  source       String  @default("manual") // manual, api
  createdAt    DateTime @default(now())

  @@index([fromCurrency, toCurrency, createdAt])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON string for flexible value storage
  label String // Human-readable label
  group String @default("general") // Grouping: general, currency, denominations, etc.
}
