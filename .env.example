# KioskoApp — Variables de entorno (desarrollo)
# Copiar este archivo a .env y ajustar si hace falta:  cp .env.example .env

# Base de datos SQLite — ruta RELATIVA al directorio del proyecto
# (usar ruta relativa, no absoluta, para que funcione en cualquier máquina)
DATABASE_URL="file:./db/custom.db"

# Entorno
NODE_ENV=development
PORT=3000

# License-server (mini-servicio en puerto 3042)
LICENSE_SERVER_URL=http://localhost:3042

# Secret para firmar cookies de licencia (middleware/proxy.ts)
# Generar uno aleatorio con: openssl rand -hex 32
LICENSE_COOKIE_SECRET=change-me-in-production

# URL del servidor de licencias (para el panel admin)
NEXT_PUBLIC_LICENSE_SERVER_URL=http://localhost:3042
